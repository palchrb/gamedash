{
  "services": [
    {
      "id": "mc1",
      "name": "Minecraft",
      "type": "minecraft",
      "container": "minecraft-mc-1",
      "rcon": {
        "host": "mc",
        "port": 25575,
        "passwordEnv": "RCON_PASSWORD"
      },
      "ports": [
        { "port": "25565", "proto": "tcp" },
        { "port": "19132", "proto": "udp" },
        { "port": "24454", "proto": "udp" }
      ],
      "connectAddress": "play.example.com",
      "mapUrl": "https://map.example.com",
      "mapProxy": {
        "host": "bluemap",
        "port": 8100,
        "scheme": "http"
      },
      "dataDir": "/mc-data"
    },
    {
      "id": "impostor",
      "name": "Among Us",
      "type": "generic",
      "container": "impostor",
      "connectAddress": "play.example.com:22023",
      "connectHelper": {
        "type": "impostor",
        "scheme": "http",
        "name": "My Server"
      },
      "ports": [
        { "port": "22023", "proto": "udp" }
      ]
    },
    {
      "id": "terraria",
      "name": "Terraria",
      "type": "tshock",
      "container": "terraria",
      "connectAddress": "play.example.com:7777",
      "_comment_tshock": "Configure an Application REST Token in tshock config.json — runtime /v2/token/create tokens don't survive restart. Token name must be hard to guess.",
      "tshockApiToken": "your-application-rest-token-here",
      "ports": [
        { "port": "7777", "proto": "tcp" }
      ]
    }
  ]
}
