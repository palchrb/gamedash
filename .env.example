# gamedash — sample environment file.
#
# Copy to `.env` and edit. Docker Compose reads `.env` automatically
# when you run `docker compose up`. Every variable here is optional
# except RCON_PASSWORD, which the compose file requires.
#
# All values are validated with Zod at start-up; a bad value crashes
# the container with a clear error rather than a silent misconfig.

# ─────────────────────────────────────────────────────────────────────
# Secrets (required)
# ─────────────────────────────────────────────────────────────────────

# RCON password shared between the Minecraft container and the
# dashboard. docker-compose.yml refuses to start without this.
RCON_PASSWORD=change-me-please

# ─────────────────────────────────────────────────────────────────────
# HTTP + reverse proxy
# ─────────────────────────────────────────────────────────────────────

# Port the dashboard listens on inside the container. Usually you map
# this in docker-compose.yml rather than changing it here.
# API_PORT=3000

# Express `trust proxy` value. Leave as `loopback` for a bare setup.
# Behind a reverse proxy that terminates TLS, set to the proxy's IP(s)
# (comma-separated) or `true`. Required for correct req.ip behind nginx
# / Caddy / Traefik — without it the IP allow-list will see the proxy's
# address instead of the real client.
# TRUST_PROXY=loopback

# ─────────────────────────────────────────────────────────────────────
# Admin passkey auth (WebAuthn)
# ─────────────────────────────────────────────────────────────────────

# Relying-party ID: the BARE hostname the browser sees in the address
# bar (no scheme, no port). Must exactly match or WebAuthn refuses to
# register. Examples:
#   dash.example.com     → ADMIN_RP_ID=dash.example.com
#   http://localhost:3000 → ADMIN_RP_ID=localhost
# ADMIN_RP_ID=localhost

# Display name shown to the user in the OS passkey prompt.
# ADMIN_RP_NAME=GameDash

# Expected origin: the FULL URL the browser uses (scheme + host + port
# when non-standard). Must match character-for-character.
#   https://dash.example.com            → no :443
#   http://localhost:3000               → keep the :3000
# ADMIN_ORIGIN=http://localhost:3000

# Sliding session lifetime. The cookie refreshes on every hit, so as
# long as you come back within this window your session survives.
# ADMIN_SESSION_TTL_HOURS=12

# Hard re-auth deadline. Past this, the cookie is invalidated and the
# user must redo the passkey ceremony. Acts as a ceiling on how long a
# session can slide forward.
# ADMIN_REAUTH_AFTER_HOURS=168

# How long the first-admin bootstrap window stays open on startup.
# Only relevant on the very first run (no admins exist yet). Restart
# the container to re-open it.
# ADMIN_BOOTSTRAP_WINDOW_MINUTES=15

# ─────────────────────────────────────────────────────────────────────
# Per-child knock PWA
# ─────────────────────────────────────────────────────────────────────

# Require a passkey on /u/<token> in addition to the URL token. When
# true, every child must register a passkey during the enrolment window
# below before they can knock.
# KNOCK_REQUIRE_PASSKEY=false

# Knock session cookie TTL (passkey mode only). Default 30 days — the
# idea is "install once and play forever" so long as your passkey is
# still on the device.
# KNOCK_PASSKEY_REAUTH_HOURS=720

# How long the per-user registration window stays open when you create
# a new user or call /open-registration from the admin UI.
# KNOCK_REGISTRATION_TTL_HOURS=24

# How long a successful knock keeps the firewall rule alive.
# KNOCK_USER_TTL_HOURS=24

# CIDR ranges the knock flow silently ignores (comma-separated). Useful
# for CGNAT / Tailscale / WireGuard ranges where an "IP allow-list"
# doesn't make sense. 100.64.0.0/10 is IANA CGNAT.
# KNOCK_IGNORE_RANGES=100.64.0.0/10

# ─────────────────────────────────────────────────────────────────────
# Service registry + i18n
# ─────────────────────────────────────────────────────────────────────

# Which service from services.json is picked when the UI doesn't ask
# for a specific one.
# DEFAULT_SERVICE_ID=mc1

# UI default language. Additional locales go in api/locales/*.json.
# DEFAULT_LOCALE=en

# URL of the UFW sidecar HTTP API. Change only if you rename the
# sidecar container or expose it on a different port.
# UFW_SIDECAR_URL=http://ufw-sidecar:9090

# ─────────────────────────────────────────────────────────────────────
# Storage layout
# ─────────────────────────────────────────────────────────────────────

# Root directory for every JSON state file. Bind-mount this to a host
# path you back up.
# DATA_DIR=/mcdata

# Individual file overrides. Leave unset to use the defaults under
# $DATA_DIR — they are here for advanced layouts only.
# SERVICES_FILE=/mcdata/services.json
# USERS_FILE=/mcdata/users.json
# FIREWALL_RULES_FILE=/mcdata/firewall-rules.json
# STATS_FILE=/mcdata/stats.json
# AUDIT_LOG=/mcdata/audit.log
# ADMIN_CREDENTIALS_FILE=/mcdata/admin-credentials.json
# ADMIN_SESSIONS_FILE=/mcdata/admin-sessions.json
# KNOCK_SESSIONS_FILE=/mcdata/knock-sessions.json
# UPLOADS_DIR=/mcdata/uploads

# ─────────────────────────────────────────────────────────────────────
# Audit log rotation
# ─────────────────────────────────────────────────────────────────────

# Rotate audit.log when it exceeds this many bytes (default 10 MiB).
# AUDIT_LOG_MAX_BYTES=10485760

# How many rotated generations to keep. Older ones are deleted on roll.
# AUDIT_LOG_MAX_FILES=5

# ─────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────

# pino level: fatal | error | warn | info | debug | trace | silent
# LOG_LEVEL=info

# Pretty-print logs to stdout. Leave false in production so Docker /
# journald / Loki get structured JSON. Set true for local `npm run dev`.
# LOG_PRETTY=false

# NODE_ENV=production
